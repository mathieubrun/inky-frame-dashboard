meta {
  name: Get Dashboard Image with ETag
  type: http
  seq: 9
}

get {
  url: {{base_url}}/dashboard/image?location=Zurich
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.headers.etag: isDefined
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("last_etag", res.headers.etag);
  }
}
