meta {
  name: Get Dashboard Image
  type: http
  seq: 5
}

get {
  url: {{base_url}}/dashboard/image?location=Nyon&mock=true
  body: none
  auth: none
}

params:query {
  location: Nyon
  mock: true
  ~calendar_id: primary
  ~palette: spectra6
}

assert {
  res.status: 200
  res.headers["content-type"]: image/png
}
