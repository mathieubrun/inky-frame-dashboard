meta {
  name: Get Swiss Weather
  type: http
  seq: 2
}

get {
  url: {{base_url}}/weather/swiss?city=Zurich&mock=true
  body: none
  auth: none
}

params:query {
  city: Zurich
  mock: true
}

assert {
  res.status: eq 200
  res.body.location.city: eq Zurich
  res.body.current.temperature: isNumber
  res.body.source: eq Mock Provider
}
