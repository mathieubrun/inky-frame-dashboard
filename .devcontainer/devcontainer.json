{
	"name": "golang",
	"image": "mcr.microsoft.com/devcontainers/go:1-1.24-bookworm",
	"features": {
		"ghcr.io/devcontainers/features/node:1": {
			"version": "lts",
			"pnpmVersion": "latest",
			"nvmVersion": "latest"
		}
	},
	"forwardPorts": [8080],
	"postCreateCommand": "npm install -g @google/gemini-cli",
	"customizations": {
		"vscode": {
			"extensions": [
				"mhutchie.git-graph",
				"golang.go",
				"google.gemini-cli-vscode-ide-companion"
			]
		}
	}
}